---
import Layout from "../layouts/Layout.astro";
import JsonLd from "../components/JsonLd.astro";
import TarjetaProyecto from "../components/TarjetaProyecto.astro";
import { sitio } from "../data/sitio";
import { proyectos } from "../data/proyectos";
import { linkWhatsapp } from "../lib/whatsapp";
import { labelTipo } from "../lib/formato";
import { websiteJsonLd, organizationJsonLd } from "../lib/seo";
import { withBase } from "../lib/rutas";

const base = Astro.site!;
const mensaje = `Hola, quisiera más información sobre los proyectos de ${sitio.marcaPlataforma}.`;
const whatsappUrl = linkWhatsapp(sitio.contacto.whatsapp, mensaje);

// Burbujas de acceso rápido (estilo portal): se arman solas con los datos.
// Primero los tipos presentes, luego los departamentos con proyectos. Cada
// una lleva a /proyectos ya filtrado.
const tiposPresentes = Array.from(new Set(proyectos.map((p) => p.tipo)));
const departamentosPresentes = Array.from(
  new Set(proyectos.map((p) => p.departamento))
).sort();

type Burbuja = { label: string; href: string; icono: "playa" | "urbano" | "residencial" | "zona" };
const burbujas: Burbuja[] = [
  ...tiposPresentes.map((t) => ({
    label: labelTipo[t],
    href: `/proyectos?tipo=${t}`,
    icono: t as Burbuja["icono"],
  })),
  ...departamentosPresentes.map((d) => ({
    label: d,
    href: `/proyectos?zona=${encodeURIComponent(d.toLowerCase())}`,
    icono: "zona" as const,
  })),
];

// Proyectos destacados para la portada (call to action). Se eligen por el
// campo `destacado`; si ninguno lo tiene, se muestran los primeros. Máximo 3.
const destacados = (
  proyectos.some((p) => p.destacado)
    ? proyectos.filter((p) => p.destacado)
    : proyectos
).slice(0, 3);
---

<Layout
  titulo={`${sitio.marcaPlataforma} — Lotes en El Salvador para la diáspora salvadoreña`}
  descripcion="Encontrá lotes en lotificaciones confiables en El Salvador. Confianza, datos claros y contacto directo por WhatsApp."
>
  <JsonLd slot="head" data={websiteJsonLd(base)} />
  <JsonLd slot="head" data={organizationJsonLd(base)} />
  <!-- Foto real de Condado del Golfo (vista aérea, golfo de Fonseca): da el
       tono aspiracional de costa/horizonte de El Salvador con una imagen
       100% propia, sin recurrir a stock de terceros. -->
  <section class="relative text-cream overflow-hidden">
    <img
      src={withBase("/assets/proyectos/condado-del-golfo/panoramica-golfo.webp")}
      alt="Vista aérea de la costa de El Salvador"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-navy/85 via-navy/75 to-navy-deep/90"></div>
    <div class="relative mx-auto max-w-6xl px-4 py-20 sm:py-28 text-center">
      <h1 class="font-display text-3xl sm:text-5xl leading-tight max-w-3xl mx-auto">
        Tu propiedad en El Salvador, con confianza y acompañamiento
      </h1>
      <p class="mt-5 text-base sm:text-lg text-cream/80 max-w-2xl mx-auto">
        Conectamos a los salvadoreños —dentro y fuera del país— con lotes y
        proyectos confiables. Te asesoramos en cada paso del proceso y, con
        nuestra red de contactos en El Salvador, armamos soluciones a tu
        medida. Información clara, sin sorpresas, y un asesor real siempre a un
        mensaje de distancia.
      </p>
      <!-- Buscador protagonista (F1): dos menús desplegables (tipo de
           lotificación + departamento) que llevan a /proyectos ya filtrado.
           La página de listado lee ?tipo= y ?zona= de la URL. -->
      <form
        action={withBase("/proyectos")}
        method="get"
        class="mt-8 mx-auto max-w-3xl flex flex-col sm:flex-row gap-2 bg-white/95 rounded-2xl sm:rounded-full p-2 shadow-lg"
      >
        <!-- Tipo de lotificación -->
        <div class="relative flex-1">
          <label for="h-tipo" class="sr-only">Tipo de lotificación</label>
          <svg xmlns="http://www.w3.org/2000/svg" class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-sand-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v10h14V10" />
          </svg>
          <select
            id="h-tipo"
            name="tipo"
            class="w-full appearance-none bg-transparent text-navy font-medium pl-11 pr-9 py-3 rounded-full focus:outline-none cursor-pointer"
          >
            <option value="">Todo tipo de lote</option>
            {tiposPresentes.map((t) => <option value={t}>{labelTipo[t]}</option>)}
          </select>
          <svg xmlns="http://www.w3.org/2000/svg" class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-navy/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
        </div>

        <!-- Separador en escritorio -->
        <span class="hidden sm:block w-px bg-navy/10 my-2"></span>

        <!-- Departamento / zona -->
        <div class="relative flex-1">
          <label for="h-zona" class="sr-only">Departamento</label>
          <svg xmlns="http://www.w3.org/2000/svg" class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 h-5 w-5 text-sand-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
          </svg>
          <select
            id="h-zona"
            name="zona"
            class="w-full appearance-none bg-transparent text-navy font-medium pl-11 pr-9 py-3 rounded-full focus:outline-none cursor-pointer"
          >
            <option value="">Todos los departamentos</option>
            {departamentosPresentes.map((d) => <option value={d.toLowerCase()}>{d}</option>)}
          </select>
          <svg xmlns="http://www.w3.org/2000/svg" class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 h-4 w-4 text-navy/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
        </div>

        <button
          type="submit"
          class="flex items-center justify-center gap-2 bg-sand text-navy font-semibold px-7 py-3 rounded-full hover:bg-sand-light transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.3-4.3M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16Z" /></svg>
          Buscar
        </button>
      </form>

      <!-- Burbujas de acceso rápido: tipos y departamentos con proyectos -->
      <div class="mt-5 flex flex-wrap justify-center gap-2">
        {burbujas.map((b) => (
          <a
            href={withBase(b.href)}
            class="inline-flex items-center gap-2 rounded-full border border-cream/30 bg-cream/5 px-4 py-2 text-sm text-cream hover:bg-cream/15 hover:border-sand transition-colors"
          >
            {b.icono === "zona" && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-sand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z" />
              </svg>
            )}
            {b.icono === "playa" && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-sand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2 13c2-2 4-2 6 0s4 2 6 0 4-2 6 0M2 18c2-2 4-2 6 0s4 2 6 0 4-2 6 0" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v4" />
              </svg>
            )}
            {b.icono === "urbano" && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-sand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 21h18M6 21V5a1 1 0 011-1h6a1 1 0 011 1v16M14 21V9h4v12M9 8h2M9 12h2" />
              </svg>
            )}
            {b.icono === "residencial" && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-sand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v10h14V10" />
              </svg>
            )}
            {b.label}
          </a>
        ))}
      </div>

      <div class="mt-5 flex flex-col sm:flex-row gap-3 justify-center text-sm">
        <a href={withBase("/proyectos")} class="underline hover:text-sand transition-colors">
          Ver todos los proyectos
        </a>
        <span class="hidden sm:inline text-cream/40">·</span>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="underline hover:text-sand transition-colors"
        >
          O escribinos por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- Proyectos destacados: call to action visual hacia las fichas -->
  {destacados.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 py-14">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-2 mb-6">
        <div>
          <h2 class="font-display text-2xl sm:text-3xl">Proyectos destacados</h2>
          <p class="text-navy/70 mt-1">
            Una selección de lotificaciones para conocer hoy.
          </p>
        </div>
        <a href={withBase("/proyectos")} class="text-navy font-semibold underline hover:text-sand transition-colors whitespace-nowrap">
          Ver todos los proyectos
        </a>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {destacados.map((p) => <TarjetaProyecto proyecto={p} />)}
      </div>
    </section>
  )}

  <!-- Bloques de audiencia: la distinción de origen aporta valor porque cada
       perfil tiene necesidades y retos distintos. Cada tarjeta muestra las
       soluciones que coordinamos para ese perfil (one-stop-shop), con marco
       "coordinamos/orientamos con nuestra red de aliados" (sin sobreprometer). -->
  <section class="bg-surface-soft py-16">
    <div class="mx-auto max-w-6xl px-4">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <h2 class="font-display text-2xl sm:text-3xl">¿Desde dónde comprás?</h2>
        <p class="text-navy/70 mt-2">
          Cada situación es distinta. Te armamos una solución a la medida y
          coordinamos cada gestión con nuestra red de aliados en El Salvador.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        <!-- Comprador desde el exterior (diáspora) -->
        <div class="group relative overflow-hidden rounded-2xl bg-navy text-cream p-8 shadow-[var(--shadow-card)] flex flex-col">
          <span class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-sand/10"></span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-9 w-9 text-sand mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.6 9h16.8M3.6 15h16.8M11.5 3a17 17 0 0 0 0 18M12.5 3a17 17 0 0 1 0 18" />
            <circle cx="12" cy="12" r="9" />
          </svg>
          <h3 class="font-display text-xl mb-1">Comprás desde el exterior</h3>
          <p class="text-sm text-cream/70 mb-4">
            Invertí en tu tierra sin tener que viajar para empezar, con respaldo
            en cada paso.
          </p>
          <ul class="space-y-2.5 text-sm text-cream/85 flex-1">
            <li class="flex gap-2.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-sand shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="m9 12.75 1.5 1.5 3-3.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
              <span>Compra a distancia: te orientamos con el poder legalizado/apostillado o la compra a nombre de un familiar de confianza.</span>
            </li>
            <li class="flex gap-2.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-sand shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="m9 12.75 1.5 1.5 3-3.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
              <span>Verificación legal del lote (estudio registral y linderos) antes de que pongás un dólar.</span>
            </li>
            <li class="flex gap-2.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-sand shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="m9 12.75 1.5 1.5 3-3.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
              <span>Fotos, recorrido y un asesor real que te representa en El Salvador.</span>
            </li>
          </ul>
          <a
            href={withBase("/proyectos")}
            class="mt-6 inline-flex items-center gap-2 text-sand font-semibold hover:gap-3 transition-all"
          >
            Ver proyectos
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6" /></svg>
          </a>
        </div>
        <!-- Comprador local -->
        <div class="group relative overflow-hidden rounded-2xl bg-surface border border-line p-8 shadow-[var(--shadow-card)] flex flex-col">
          <span class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-sand/10"></span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-9 w-9 text-sand-dark mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v10h14V10" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 21v-6h6v6" />
          </svg>
          <h3 class="font-display text-xl mb-1 text-navy">Comprás en El Salvador</h3>
          <p class="text-sm text-navy/60 mb-4">
            Conocé el lote en persona y avanzá con agilidad y respaldo.
          </p>
          <ul class="space-y-2.5 text-sm text-navy/75 flex-1">
            <li class="flex gap-2.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-sand-dark shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="m9 12.75 1.5 1.5 3-3.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
              <span>Coordinamos tu visita y recorrido al lote cuando te quede mejor.</span>
            </li>
            <li class="flex gap-2.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-sand-dark shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="m9 12.75 1.5 1.5 3-3.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
              <span>Te orientamos en las opciones de financiamiento: plan directo del desarrollador o crédito.</span>
            </li>
            <li class="flex gap-2.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-sand-dark shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path stroke-linecap="round" stroke-linejoin="round" d="m9 12.75 1.5 1.5 3-3.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
              <span>Acompañamos la escrituración y los trámites hasta que el lote quede a tu nombre.</span>
            </li>
          </ul>
          <a
            href={withBase("/proyectos")}
            class="mt-6 inline-flex items-center gap-2 text-navy font-semibold hover:gap-3 transition-all"
          >
            Ver proyectos
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Cadena de valor (one-stop-shop): apoyo visual a "te acompañamos de
       principio a fin". Derivada del análisis de necesidades de cada perfil.
       Marco honesto: coordinamos/orientamos con nuestra red de aliados. -->
  <section class="bg-navy-deep text-cream py-16">
    <div class="mx-auto max-w-6xl px-4">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <p class="text-sand font-semibold uppercase tracking-wider text-sm mb-2">Un solo lugar</p>
        <h2 class="font-display text-2xl sm:text-3xl text-cream">Te acompañamos de principio a fin</h2>
        <p class="text-cream/70 mt-2">
          No solo te mostramos el lote: coordinamos y orientamos cada paso del
          proceso con nuestra red de aliados en El Salvador.
        </p>
      </div>

      {/* Pasos de la cadena de valor. Data-driven para mantenerlos en un solo lugar. */}
      <ol class="relative grid gap-8 sm:grid-cols-2 lg:grid-cols-6 lg:gap-4">
        {[
          { t: "Asesoría", d: "Entendemos tu objetivo y tu situación." },
          { t: "Verificación legal", d: "Estudio registral y linderos del lote." },
          { t: "Estructura de compra", d: "Poder, titularidad o financiamiento." },
          { t: "Pago", d: "Te guiamos en prima y cuotas, con comprobantes." },
          { t: "Escrituración", d: "Trámites hasta dejar el lote a tu nombre." },
          { t: "Post-venta", d: "Impuestos, construcción y cuido del lote." },
        ].map((paso, i) => (
          <li class="relative flex flex-col items-center text-center lg:items-start lg:text-left">
            <span class="grid h-11 w-11 place-items-center rounded-full bg-sand text-navy font-display font-bold text-lg shadow-[var(--shadow-float)] z-10">
              {i + 1}
            </span>
            <p class="font-semibold mt-3">{paso.t}</p>
            <p class="text-xs text-cream/65 mt-1 max-w-[22ch]">{paso.d}</p>
          </li>
        ))}
        <!-- Línea conectora (solo escritorio) -->
        <span class="hidden lg:block absolute top-[22px] left-[8%] right-[8%] h-px bg-cream/15"></span>
      </ol>
    </div>
  </section>

  <!-- Banda de confianza (Paso 5): tres pilares con ícono. Refuerza la
       jerarquía Confianza → Inteligencia → Conversación del proyecto. -->
  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="grid gap-8 sm:grid-cols-3">
      <div class="flex flex-col items-center text-center sm:items-start sm:text-left">
        <span class="grid h-12 w-12 place-items-center rounded-xl bg-sand/15 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-sand-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </span>
        <p class="font-display text-lg mb-1">Confianza primero</p>
        <p class="text-sm text-navy/70">
          Información clara y verificada de cada proyecto, sin promesas vacías.
        </p>
      </div>
      <div class="flex flex-col items-center text-center sm:items-start sm:text-left">
        <span class="grid h-12 w-12 place-items-center rounded-xl bg-sand/15 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-sand-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.96 11.96 0 0 1 3.6 6.3a12 12 0 0 0 8.4 14.7 12 12 0 0 0 8.4-14.7 11.96 11.96 0 0 1-8.4-3.586Z" />
          </svg>
        </span>
        <p class="font-display text-lg mb-1">Proyectos verificados</p>
        <p class="text-sm text-navy/70">
          Trabajamos con desarrolladores establecidos, comenzando con Grupo
          Inmobiliario Chacón.
        </p>
      </div>
      <div class="flex flex-col items-center text-center sm:items-start sm:text-left">
        <span class="grid h-12 w-12 place-items-center rounded-xl bg-sand/15 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-sand-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.12 2.94 2.62 3.27.5.11.88.55.88 1.06v2.16c0 .58.66.9 1.12.55l2.4-1.83c.2-.16.46-.24.72-.24h4.51c1.86 0 3.5-1.48 3.5-3.36V7.36C18.5 5.48 16.86 4 15 4H6c-1.86 0-3.5 1.48-3.5 3.36v6.4Z" />
          </svg>
        </span>
        <p class="font-display text-lg mb-1">Atención directa</p>
        <p class="text-sm text-navy/70">
          Hablás por WhatsApp con una persona real, no con un formulario sin
          respuesta.
        </p>
      </div>
    </div>
  </section>

  <!-- Cierre de conversión (Paso 5): banda navy con CTA fuerte a WhatsApp. -->
  <section class="bg-navy text-cream">
    <div class="mx-auto max-w-6xl px-4 py-16 grid gap-10 md:grid-cols-2 md:items-center">
      <div>
        <p class="text-sand font-semibold uppercase tracking-wider text-sm mb-3">Hablemos hoy</p>
        <h2 class="font-display text-2xl sm:text-3xl mb-4 text-cream">
          ¿Tenés dudas sobre un lote? <span class="acento">Escribinos por WhatsApp</span>
        </h2>
        <p class="text-cream/75 max-w-md mb-7">
          Te respondemos con fotos, ubicación exacta, precios y disponibilidad.
          Sin compromiso y con una persona real del otro lado.
        </p>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-evento="click_whatsapp"
          class="inline-flex items-center gap-2.5 bg-sand text-navy font-semibold px-6 py-3.5 rounded-full hover:bg-sand-light transition-colors shadow-[var(--shadow-float)]"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M.057 24l1.687-6.163a11.867 11.867 0 0 1-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 0 1 8.413 3.488 11.82 11.82 0 0 1 3.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 0 1-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 0 0 1.51 5.26l-.999 3.648 3.477-.917z"/>
          </svg>
          Escribir por WhatsApp
        </a>
        <p class="text-cream/55 text-sm mt-4">
          O llamanos al <a href={`tel:${sitio.contacto.telefono}`} class="underline hover:text-sand">{sitio.contacto.telefono}</a>.
        </p>
      </div>
      <div class="hidden md:block">
        <div class="relative rounded-2xl border border-cream/15 bg-navy-deep/60 p-6 shadow-[var(--shadow-float)]">
          <div class="flex items-center gap-3 mb-5">
            <span class="grid h-10 w-10 place-items-center rounded-full bg-sand/20 text-sand font-display font-bold">DP</span>
            <div>
              <p class="font-semibold leading-tight">DestinoPropiedades.com</p>
              <p class="text-xs text-cream/50">en línea · responde rápido</p>
            </div>
          </div>
          <div class="space-y-2.5 text-sm">
            <p class="max-w-[80%] rounded-2xl rounded-tl-sm bg-cream/10 px-4 py-2.5">
              Hola 👋 quiero info de un lote en la playa
            </p>
            <p class="ml-auto max-w-[85%] rounded-2xl rounded-tr-sm bg-sand text-navy px-4 py-2.5">
              ¡Con gusto! Te paso fotos, ubicación y precios. ¿Para vos o para tu familia en El Salvador?
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-navy/5 py-14">
    <div class="mx-auto max-w-6xl px-4 text-center">
      <p class="font-display text-2xl mb-3">
        En alianza con {sitio.desarrolladorActual.nombre}
      </p>
      <p class="text-navy/70 max-w-2xl mx-auto mb-5">
        DestinoPropiedades.com es la plataforma; {sitio.desarrolladorActual.nombre}{" "}
        es nuestro desarrollador aliado actual para los proyectos en venta.
      </p>
      <a href={withBase("/quienes-somos")} class="text-navy font-semibold underline hover:text-sand transition-colors">
        Conocé más sobre quiénes somos
      </a>
    </div>
  </section>
</Layout>
