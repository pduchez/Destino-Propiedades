---
import Layout from "../layouts/Layout.astro";
import JsonLd from "../components/JsonLd.astro";
import TarjetaProyecto from "../components/TarjetaProyecto.astro";
import { sitio } from "../data/sitio";
import { proyectos } from "../data/proyectos";
import { linkWhatsapp } from "../lib/whatsapp";
import { labelTipo } from "../lib/formato";
import { websiteJsonLd, organizationJsonLd } from "../lib/seo";
import { withBase } from "../lib/rutas";

const base = Astro.site!;
const mensaje = `Hola, quisiera más información sobre los proyectos de ${sitio.marcaPlataforma}.`;
const whatsappUrl = linkWhatsapp(sitio.contacto.whatsapp, mensaje);

// Sugerencias para el buscador: municipios y departamentos presentes en los datos.
const sugerencias = Array.from(
  new Set(proyectos.flatMap((p) => [p.municipio, p.departamento]))
).sort();

// Burbujas de acceso rápido (estilo portal): se arman solas con los datos.
// Primero los tipos presentes, luego los departamentos con proyectos. Cada
// una lleva a /proyectos ya filtrado.
const tiposPresentes = Array.from(new Set(proyectos.map((p) => p.tipo)));
const departamentosPresentes = Array.from(
  new Set(proyectos.map((p) => p.departamento))
).sort();

type Burbuja = { label: string; href: string; icono: "playa" | "urbano" | "residencial" | "zona" };
const burbujas: Burbuja[] = [
  ...tiposPresentes.map((t) => ({
    label: labelTipo[t],
    href: `/proyectos?tipo=${t}`,
    icono: t as Burbuja["icono"],
  })),
  ...departamentosPresentes.map((d) => ({
    label: d,
    href: `/proyectos?zona=${encodeURIComponent(d.toLowerCase())}`,
    icono: "zona" as const,
  })),
];

// Proyectos destacados para la portada (call to action). Se eligen por el
// campo `destacado`; si ninguno lo tiene, se muestran los primeros. Máximo 3.
const destacados = (
  proyectos.some((p) => p.destacado)
    ? proyectos.filter((p) => p.destacado)
    : proyectos
).slice(0, 3);
---

<Layout
  titulo={`${sitio.marcaPlataforma} — Lotes en El Salvador para la diáspora salvadoreña`}
  descripcion="Encontrá lotes en lotificaciones confiables en El Salvador. Confianza, datos claros y contacto directo por WhatsApp."
>
  <JsonLd slot="head" data={websiteJsonLd(base)} />
  <JsonLd slot="head" data={organizationJsonLd(base)} />
  <!-- Foto real de Condado del Golfo (vista aérea, golfo de Fonseca): da el
       tono aspiracional de costa/horizonte de El Salvador con una imagen
       100% propia, sin recurrir a stock de terceros. -->
  <section class="relative text-cream overflow-hidden">
    <img
      src={withBase("/assets/proyectos/condado-del-golfo/panoramica-golfo.webp")}
      alt="Vista aérea de la costa de El Salvador"
      class="absolute inset-0 h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-navy/85 via-navy/75 to-navy-deep/90"></div>
    <div class="relative mx-auto max-w-6xl px-4 py-20 sm:py-28 text-center">
      <h1 class="font-display text-3xl sm:text-5xl leading-tight max-w-3xl mx-auto">
        Tu lote en El Salvador, a un mensaje de distancia
      </h1>
      <p class="mt-5 text-base sm:text-lg text-cream/80 max-w-2xl mx-auto">
        Lotes en lotificaciones confiables, pensados para salvadoreños que
        construyen su futuro desde Estados Unidos. Información clara, sin
        sorpresas, y contacto directo con un asesor real.
      </p>
      <!-- Buscador protagonista (F1): lleva a resultados filtrados en /proyectos -->
      <form
        action={withBase("/proyectos")}
        method="get"
        class="mt-8 mx-auto max-w-xl flex flex-col sm:flex-row gap-2 bg-white/95 rounded-2xl sm:rounded-full p-2 shadow-lg"
      >
        <label for="buscar-zona" class="sr-only">Buscar por zona o municipio</label>
        <input
          id="buscar-zona"
          type="text"
          name="q"
          list="sugerencias-zona"
          placeholder="¿En qué zona buscás? Ej. Sonsonate, El Zonte..."
          class="flex-1 bg-transparent text-navy placeholder:text-navy/50 px-4 py-3 focus:outline-none"
        />
        <datalist id="sugerencias-zona">
          {sugerencias.map((s) => <option value={s}></option>)}
        </datalist>
        <button
          type="submit"
          class="bg-sand text-navy font-semibold px-6 py-3 rounded-full hover:bg-sand-light transition-colors"
        >
          Buscar
        </button>
      </form>

      <!-- Burbujas de acceso rápido: tipos y departamentos con proyectos -->
      <div class="mt-5 flex flex-wrap justify-center gap-2">
        {burbujas.map((b) => (
          <a
            href={withBase(b.href)}
            class="inline-flex items-center gap-2 rounded-full border border-cream/30 bg-cream/5 px-4 py-2 text-sm text-cream hover:bg-cream/15 hover:border-sand transition-colors"
          >
            {b.icono === "zona" && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-sand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z" />
              </svg>
            )}
            {b.icono === "playa" && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-sand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2 13c2-2 4-2 6 0s4 2 6 0 4-2 6 0M2 18c2-2 4-2 6 0s4 2 6 0 4-2 6 0" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v4" />
              </svg>
            )}
            {b.icono === "urbano" && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-sand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 21h18M6 21V5a1 1 0 011-1h6a1 1 0 011 1v16M14 21V9h4v12M9 8h2M9 12h2" />
              </svg>
            )}
            {b.icono === "residencial" && (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-sand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v10h14V10" />
              </svg>
            )}
            {b.label}
          </a>
        ))}
      </div>

      <div class="mt-5 flex flex-col sm:flex-row gap-3 justify-center text-sm">
        <a href={withBase("/proyectos")} class="underline hover:text-sand transition-colors">
          Ver todos los proyectos
        </a>
        <span class="hidden sm:inline text-cream/40">·</span>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="underline hover:text-sand transition-colors"
        >
          O escribinos por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- Proyectos destacados: call to action visual hacia las fichas -->
  {destacados.length > 0 && (
    <section class="mx-auto max-w-6xl px-4 py-14">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-2 mb-6">
        <div>
          <h2 class="font-display text-2xl sm:text-3xl">Proyectos destacados</h2>
          <p class="text-navy/70 mt-1">
            Una selección de lotificaciones para conocer hoy.
          </p>
        </div>
        <a href={withBase("/proyectos")} class="text-navy font-semibold underline hover:text-sand transition-colors whitespace-nowrap">
          Ver todos los proyectos
        </a>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {destacados.map((p) => <TarjetaProyecto proyecto={p} />)}
      </div>
    </section>
  )}

  <!-- Bloques de audiencia (Paso 4): habla directo a los dos perfiles de
       comprador. Cada uno lleva al mismo listado, pero con el mensaje y el
       encuadre que le corresponde. -->
  <section class="bg-surface-soft py-16">
    <div class="mx-auto max-w-6xl px-4">
      <div class="text-center max-w-2xl mx-auto mb-10">
        <h2 class="font-display text-2xl sm:text-3xl">¿Desde dónde comprás?</h2>
        <p class="text-navy/70 mt-2">
          Te acompañamos igual de cerca, estés donde estés.
        </p>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        <!-- Diáspora en EE.UU. -->
        <div class="group relative overflow-hidden rounded-2xl bg-navy text-cream p-8 shadow-[var(--shadow-card)] flex flex-col">
          <span class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-sand/10"></span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-9 w-9 text-sand mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.6 9h16.8M3.6 15h16.8M11.5 3a17 17 0 0 0 0 18M12.5 3a17 17 0 0 1 0 18" />
            <circle cx="12" cy="12" r="9" />
          </svg>
          <h3 class="font-display text-xl mb-2">Comprás desde Estados Unidos</h3>
          <p class="text-sm text-cream/75 flex-1">
            Invertí en tu tierra sin tener que viajar para empezar. Te enviamos
            fotos, ubicación exacta, precios y disponibilidad por WhatsApp, y
            coordinamos cada paso con tu familia en El Salvador.
          </p>
          <a
            href={withBase("/proyectos")}
            class="mt-6 inline-flex items-center gap-2 text-sand font-semibold hover:gap-3 transition-all"
          >
            Ver proyectos para la diáspora
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6" /></svg>
          </a>
        </div>
        <!-- Comprador local -->
        <div class="group relative overflow-hidden rounded-2xl bg-surface border border-line p-8 shadow-[var(--shadow-card)] flex flex-col">
          <span class="absolute -right-6 -top-6 h-24 w-24 rounded-full bg-sand/10"></span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-9 w-9 text-sand-dark mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.6">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v10h14V10" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 21v-6h6v6" />
          </svg>
          <h3 class="font-display text-xl mb-2 text-navy">Comprás en El Salvador</h3>
          <p class="text-sm text-navy/70 flex-1">
            Conocé el lote en persona, recorré la lotificación y resolvé tus
            dudas con un asesor real. Lotificaciones con servicios, escritura y
            planes de pago claros.
          </p>
          <a
            href={withBase("/proyectos")}
            class="mt-6 inline-flex items-center gap-2 text-navy font-semibold hover:gap-3 transition-all"
          >
            Ver proyectos disponibles
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-14 grid gap-8 sm:grid-cols-3 text-center">
    <div>
      <p class="font-display text-xl mb-1">Confianza primero</p>
      <p class="text-sm text-navy/70">
        Información clara y verificada de cada proyecto, sin promesas vacías.
      </p>
    </div>
    <div>
      <p class="font-display text-xl mb-1">Proyectos verificados</p>
      <p class="text-sm text-navy/70">
        Trabajamos con desarrolladores establecidos, comenzando con Grupo
        Inmobiliario Chacón.
      </p>
    </div>
    <div>
      <p class="font-display text-xl mb-1">Atención directa</p>
      <p class="text-sm text-navy/70">
        Hablás por WhatsApp con una persona real, no con un formulario sin
        respuesta.
      </p>
    </div>
  </section>

  <section class="bg-navy/5 py-14">
    <div class="mx-auto max-w-6xl px-4 text-center">
      <p class="font-display text-2xl mb-3">
        En alianza con {sitio.desarrolladorActual.nombre}
      </p>
      <p class="text-navy/70 max-w-2xl mx-auto mb-5">
        DestinoPropiedades.com es la plataforma; {sitio.desarrolladorActual.nombre}{" "}
        es nuestro desarrollador aliado actual para los proyectos en venta.
      </p>
      <a href={withBase("/quienes-somos")} class="text-navy font-semibold underline hover:text-sand transition-colors">
        Conocé más sobre quiénes somos
      </a>
    </div>
  </section>
</Layout>
