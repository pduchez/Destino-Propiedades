---
// Página de favoritos. Renderiza todas las tarjetas (sitio estático) y, en el
// navegador, muestra solo las que el visitante marcó con ❤️ (localStorage).
// Sin backend: si no hay favoritos, muestra un estado vacío con CTA.
import Layout from "../layouts/Layout.astro";
import TarjetaProyecto from "../components/TarjetaProyecto.astro";
import { proyectos } from "../data/proyectos";
import { sitio } from "../data/sitio";
---

<Layout
  titulo={`Mis favoritos — ${sitio.marcaPlataforma}`}
  descripcion="Los proyectos que guardaste para revisar después. Tus favoritos se guardan en tu propio dispositivo."
>
  <section class="mx-auto max-w-6xl px-4 py-10">
    <h1 class="font-display text-3xl sm:text-4xl mb-1">Mis favoritos</h1>
    <p id="fav-intro" class="text-navy/70 mb-6"></p>

    <!-- Grilla: todas las tarjetas, pero JS oculta las no favoritas. -->
    <div id="fav-grilla" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {proyectos.map((p) => <TarjetaProyecto proyecto={p} />)}
    </div>

    <!-- Estado vacío -->
    <div id="fav-vacio" class="hidden text-center py-16">
      <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-12 w-12 text-navy/20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
      </svg>
      <p class="mt-4 text-navy/70">Todavía no guardaste ningún proyecto.</p>
      <p class="text-navy/50 text-sm mt-1">
        Tocá el corazón ❤️ en cualquier proyecto para guardarlo aquí.
      </p>
      <a href="/proyectos" class="mt-6 inline-block rounded-full bg-navy text-cream px-6 py-3 font-semibold hover:bg-navy-light transition-colors">
        Ver proyectos
      </a>
    </div>
  </section>
</Layout>

<script is:inline>
  (function () {
    const grilla = document.getElementById("fav-grilla");
    const vacio = document.getElementById("fav-vacio");
    const intro = document.getElementById("fav-intro");
    if (!grilla) return;

    function favoritos() {
      try {
        const v = JSON.parse(localStorage.getItem("destino:favoritos") || "[]");
        return Array.isArray(v) ? v : [];
      } catch {
        return [];
      }
    }

    function render() {
      const favs = favoritos();
      let visibles = 0;
      grilla.querySelectorAll("[data-card]").forEach(function (card) {
        const btn = card.querySelector("[data-fav-slug]");
        const slug = btn && btn.getAttribute("data-fav-slug");
        const on = slug && favs.includes(slug);
        card.style.display = on ? "" : "none";
        if (on) visibles++;
      });

      const hay = visibles > 0;
      grilla.classList.toggle("hidden", !hay);
      if (vacio) vacio.classList.toggle("hidden", hay);
      if (intro) {
        intro.textContent = hay
          ? `${visibles} ${visibles === 1 ? "proyecto guardado" : "proyectos guardados"} en este dispositivo.`
          : "";
      }
    }

    render();
    // Re-render cuando se marca/desmarca un corazón (evento del script global).
    document.addEventListener("favoritos:cambio", render);
  })();
</script>
