---
// Páginas SEO por zona (F8): listado filtrado + texto descriptivo +
// ventajas + preguntas frecuentes, con datos estructurados (FAQ + migas).
import Layout from "../layouts/Layout.astro";
import TarjetaProyecto from "../components/TarjetaProyecto.astro";
import MigasDePan from "../components/MigasDePan.astro";
import JsonLd from "../components/JsonLd.astro";
import { zonas } from "../data/zonas";
import { proyectos } from "../data/proyectos";
import { sitio } from "../data/sitio";
import { linkWhatsapp } from "../lib/whatsapp";
import { faqJsonLd, breadcrumbJsonLd, zonaJsonLd } from "../lib/seo";

export function getStaticPaths() {
  return zonas.map((z) => ({ params: { zona: z.slug }, props: { zona: z } }));
}

const { zona } = Astro.props;
const base = Astro.site!;

const proyectosZona = proyectos.filter((p) => p.departamento === zona.departamento);

const mensaje = `Hola, me interesan los lotes en ${zona.departamento} que vi en ${sitio.marcaPlataforma}.`;
const whatsappUrl = linkWhatsapp(sitio.contacto.whatsapp, mensaje);

const migas = [
  { label: "Inicio", href: "/" },
  { label: "Proyectos", href: "/proyectos" },
  { label: zona.nombre },
];
---

<Layout
  titulo={zona.titulo}
  descripcion={zona.metaDescripcion}
  ogImage={`/assets/og/zona-${zona.slug}.jpg`}
  ogImageAlt={zona.nombre}
>
  <JsonLd slot="head" data={zonaJsonLd(zona, base)} />
  <JsonLd slot="head" data={faqJsonLd(zona.faq)} />
  <JsonLd slot="head" data={breadcrumbJsonLd(migas, base)} />

  <div class="mx-auto max-w-5xl px-4 py-6">
    <MigasDePan items={migas} />
  </div>

  <article class="mx-auto max-w-5xl px-4 pb-12">
    <h1 class="font-display text-3xl sm:text-4xl mb-4">{zona.nombre}</h1>

    <div class="prose-simple space-y-4 text-navy/80 leading-relaxed max-w-3xl">
      <p>{zona.descripcion}</p>
      <p>{zona.contexto}</p>
    </div>

    <!-- Ventajas de la zona -->
    {zona.ventajas.length > 0 && (
      <section class="mt-8">
        <h2 class="font-display text-2xl mb-3">Ventajas de la zona</h2>
        <ul class="grid gap-2 sm:grid-cols-2">
          {zona.ventajas.map((v) => (
            <li class="flex items-start gap-2 text-navy/80">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-sand shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              {v}
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- Listado de proyectos de la zona -->
    <section class="mt-10">
      <h2 class="font-display text-2xl mb-4">
        {proyectosZona.length > 0
          ? `Proyectos en ${zona.departamento}`
          : `Próximamente en ${zona.departamento}`}
      </h2>
      {proyectosZona.length > 0 ? (
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {proyectosZona.map((p) => <TarjetaProyecto proyecto={p} />)}
        </div>
      ) : (
        <p class="text-navy/70">
          Aún no tenemos proyectos publicados en esta zona. Escribinos por
          WhatsApp y te avisamos apenas haya disponibilidad.
        </p>
      )}
    </section>

    <!-- Preguntas frecuentes -->
    {zona.faq.length > 0 && (
      <section class="mt-12">
        <h2 class="font-display text-2xl mb-4">Preguntas frecuentes</h2>
        <div class="space-y-3">
          {zona.faq.map((f) => (
            <details class="group rounded-lg border border-navy/10 bg-white p-4">
              <summary class="cursor-pointer font-semibold flex items-center justify-between gap-2">
                {f.pregunta}
                <span class="text-sand transition-transform group-open:rotate-180">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </span>
              </summary>
              <p class="mt-2 text-navy/75 leading-relaxed">{f.respuesta}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    <!-- CTA WhatsApp -->
    <section class="mt-12 rounded-xl bg-navy text-cream p-6 text-center">
      <p class="font-display text-2xl mb-2">¿Te interesa esta zona?</p>
      <p class="text-cream/80 mb-4 max-w-xl mx-auto">
        Escribinos y un asesor te comparte disponibilidad, precios y formas de
        pago de los proyectos en {zona.departamento}.
      </p>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full bg-[#25D366] px-6 py-3 font-semibold text-white hover:opacity-90 transition-opacity"
      >
        Escribir por WhatsApp
      </a>
    </section>
  </article>
</Layout>
