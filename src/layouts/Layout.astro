---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BotonWhatsappFlotante from "../components/BotonWhatsappFlotante.astro";

interface Props {
  titulo: string;
  descripcion: string;
  ogImage?: string;
}

const { titulo, descripcion, ogImage } = Astro.props;
const urlCanonica = new URL(Astro.url.pathname, Astro.site ?? "https://destinopropiedades.com");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={urlCanonica} />

    <title>{titulo}</title>
    <meta name="description" content={descripcion} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={titulo} />
    <meta property="og:description" content={descripcion} />
    <meta property="og:url" content={urlCanonica} />
    {ogImage && <meta property="og:image" content={new URL(ogImage, urlCanonica)} />}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-cream text-navy font-sans flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <BotonWhatsappFlotante />
  </body>
</html>
