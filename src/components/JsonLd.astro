---
// Inserta datos estructurados schema.org (JSON-LD). Se usa con slot="head"
// para que caiga dentro del <head> del Layout.
// Ej: <JsonLd slot="head" data={{ "@context": "https://schema.org", ... }} />
interface Props {
  data: unknown;
}
const { data } = Astro.props;
---
<script type="application/ld+json" is:inline set:html={JSON.stringify(data)} />
