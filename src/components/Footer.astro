---
import { sitio } from "../data/sitio";
import { linkLlamar, linkWhatsapp } from "../lib/whatsapp";

const mensajeGenerico = `Hola, quisiera más información sobre los proyectos de ${sitio.marcaPlataforma}.`;
const whatsappUrl = linkWhatsapp(sitio.contacto.whatsapp, mensajeGenerico);
const telUrl = linkLlamar(sitio.contacto.telefono);

// Enlaces que ya tienen página real en el sitio. Privacidad y Términos se
// agregan en la Fase 5 — no se enlazan antes para no dejar links rotos.
const enlaces = [
  { href: "/", label: "Inicio" },
  { href: "/proyectos", label: "Proyectos" },
  { href: "/quienes-somos", label: "¿Quiénes Somos?" },
];

// Solo se muestra el ícono de una red social si tiene URL real.
const redes = [
  { nombre: "Facebook", url: sitio.redes.facebook },
  { nombre: "Instagram", url: sitio.redes.instagram },
].filter((r) => r.url);
---

<footer class="bg-navy text-cream mt-16">
  <div class="mx-auto max-w-6xl px-4 py-10 grid gap-8 sm:grid-cols-3">
    <div>
      <p class="font-display text-xl mb-2">{sitio.marcaPlataforma}</p>
      <p class="text-sm text-cream/70">
        En alianza con {sitio.desarrolladorActual.nombre}.
      </p>
    </div>

    <div>
      <p class="font-semibold mb-2 text-sm uppercase tracking-wide text-sand">
        Enlaces
      </p>
      <ul class="space-y-1 text-sm">
        {enlaces.map((e) => (
          <li><a href={e.href} class="hover:text-sand transition-colors">{e.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <p class="font-semibold mb-2 text-sm uppercase tracking-wide text-sand">
        Contacto
      </p>
      <ul class="space-y-1 text-sm">
        <li><a href={telUrl} class="hover:text-sand transition-colors">{sitio.contacto.telefono}</a></li>
        <li><a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="hover:text-sand transition-colors">WhatsApp</a></li>
        <li><a href={`mailto:${sitio.contacto.correo}`} class="hover:text-sand transition-colors">{sitio.contacto.correo}</a></li>
      </ul>
      {redes.length > 0 && (
        <div class="flex gap-3 mt-3">
          {redes.map((r) => (
            <a href={r.url} target="_blank" rel="noopener noreferrer" class="text-sm hover:text-sand transition-colors">
              {r.nombre}
            </a>
          ))}
        </div>
      )}
    </div>
  </div>

  <div class="border-t border-navy-light px-4 py-4 text-center text-xs text-cream/60">
    © {new Date().getFullYear()} {sitio.marcaPlataforma}. Todos los derechos reservados.
  </div>
</footer>
