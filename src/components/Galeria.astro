---
// Galería de fotos de la ficha de proyecto (F4): imagen grande, miniaturas,
// contador "1/N" y vista a pantalla completa (lightbox).
// Isla de interactividad con JavaScript del navegador, sin dependencias.
interface Props {
  fotos: string[];
  nombreProyecto: string;
}
const { fotos, nombreProyecto } = Astro.props;
---

<div class="galeria" data-galeria>
  <!-- Imagen principal -->
  <button
    type="button"
    class="relative block w-full overflow-hidden rounded-xl bg-navy/10 aspect-[3/2]"
    data-abrir-lightbox
    aria-label="Ver foto a pantalla completa"
  >
    <img
      data-principal
      src={fotos[0]}
      alt={`${nombreProyecto} — foto 1 de ${fotos.length}`}
      class="h-full w-full object-cover"
      loading="eager"
      width="1600"
      height="1067"
    />
    <span
      class="absolute bottom-3 right-3 rounded-full bg-navy/80 px-3 py-1 text-xs font-semibold text-cream"
      data-contador
    >
      1 / {fotos.length}
    </span>
  </button>

  <!-- Miniaturas -->
  {fotos.length > 1 && (
    <div class="mt-3 grid grid-cols-4 gap-2 sm:grid-cols-6 lg:grid-cols-8">
      {fotos.map((foto, i) => (
        <button
          type="button"
          class="overflow-hidden rounded-lg ring-2 ring-transparent aspect-[3/2] data-[activa]:ring-sand"
          data-miniatura
          data-indice={i}
          data-activa={i === 0 ? "" : null}
          aria-label={`Ver foto ${i + 1}`}
        >
          <img
            src={foto}
            alt={`${nombreProyecto} — miniatura ${i + 1}`}
            class="h-full w-full object-cover"
            loading="lazy"
            width="400"
            height="267"
          />
        </button>
      ))}
    </div>
  )}

  <!-- Lightbox a pantalla completa -->
  <div
    class="fixed inset-0 z-[60] hidden items-center justify-center bg-black/90 p-4"
    data-lightbox
    role="dialog"
    aria-modal="true"
    aria-label="Galería a pantalla completa"
  >
    <button type="button" class="absolute right-4 top-4 p-2 text-white/80 hover:text-white" data-cerrar aria-label="Cerrar">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>

    <button type="button" class="absolute left-2 sm:left-6 p-2 text-white/80 hover:text-white" data-prev aria-label="Foto anterior">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    </button>

    <img data-lightbox-img src={fotos[0]} alt={nombreProyecto} class="max-h-[85vh] max-w-[90vw] rounded-lg object-contain" />

    <button type="button" class="absolute right-2 sm:right-6 p-2 text-white/80 hover:text-white" data-next aria-label="Foto siguiente">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </button>

    <span class="absolute bottom-4 left-1/2 -translate-x-1/2 rounded-full bg-white/10 px-4 py-1 text-sm text-white" data-lightbox-contador></span>
  </div>
</div>

<script>
  function initGaleria(root: HTMLElement) {
    const fotos = Array.from(root.querySelectorAll<HTMLImageElement>("[data-miniatura] img")).map((i) => i.src);
    // Si no hay miniaturas (1 sola foto), tomar la principal.
    const principalSrc = root.querySelector<HTMLImageElement>("[data-principal]")?.src;
    const lista = fotos.length > 0 ? fotos : principalSrc ? [principalSrc] : [];
    if (lista.length === 0) return;

    const total = lista.length;
    let actual = 0;

    const principal = root.querySelector<HTMLImageElement>("[data-principal]");
    const contador = root.querySelector<HTMLElement>("[data-contador]");
    const miniaturas = Array.from(root.querySelectorAll<HTMLElement>("[data-miniatura]"));
    const lightbox = root.querySelector<HTMLElement>("[data-lightbox]");
    const lightboxImg = root.querySelector<HTMLImageElement>("[data-lightbox-img]");
    const lightboxContador = root.querySelector<HTMLElement>("[data-lightbox-contador]");

    function mostrar(i: number) {
      actual = (i + total) % total;
      if (principal) principal.src = lista[actual];
      if (contador) contador.textContent = `${actual + 1} / ${total}`;
      if (lightboxImg) lightboxImg.src = lista[actual];
      if (lightboxContador) lightboxContador.textContent = `${actual + 1} / ${total}`;
      miniaturas.forEach((m, idx) => {
        if (idx === actual) m.setAttribute("data-activa", "");
        else m.removeAttribute("data-activa");
      });
    }

    miniaturas.forEach((m) => {
      m.addEventListener("click", () => mostrar(Number(m.dataset.indice)));
    });

    function abrir() {
      lightbox?.classList.remove("hidden");
      lightbox?.classList.add("flex");
      document.body.style.overflow = "hidden";
    }
    function cerrar() {
      lightbox?.classList.add("hidden");
      lightbox?.classList.remove("flex");
      document.body.style.overflow = "";
    }

    root.querySelector("[data-abrir-lightbox]")?.addEventListener("click", abrir);
    root.querySelector("[data-cerrar]")?.addEventListener("click", cerrar);
    root.querySelector("[data-prev]")?.addEventListener("click", () => mostrar(actual - 1));
    root.querySelector("[data-next]")?.addEventListener("click", () => mostrar(actual + 1));
    lightbox?.addEventListener("click", (e) => {
      if (e.target === lightbox) cerrar();
    });
    document.addEventListener("keydown", (e) => {
      if (lightbox?.classList.contains("hidden")) return;
      if (e.key === "Escape") cerrar();
      if (e.key === "ArrowLeft") mostrar(actual - 1);
      if (e.key === "ArrowRight") mostrar(actual + 1);
    });

    mostrar(0);
  }

  document.querySelectorAll<HTMLElement>("[data-galeria]").forEach(initGaleria);
</script>
