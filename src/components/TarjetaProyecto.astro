---
// Tarjeta de proyecto estandarizada (F3). Se usa idéntica en todo el sitio:
// listado, resultados de búsqueda, páginas de zona y favoritos.
// Lleva atributos data-* para que el filtro/orden del listado funcione.
import type { Proyecto } from "../data/proyectos";
import { labelTipo, labelEstado } from "../lib/formato";
import { rangoArea, lotesDisponibles } from "../lib/relaciones";
import { etiquetaUnidad } from "../lib/formato";

interface Props {
  proyecto: Proyecto;
}
const { proyecto } = Astro.props;

const rango = rangoArea(proyecto);
const disponibles = lotesDisponibles(proyecto);
const areaTexto = rango
  ? rango.min === rango.max
    ? `${rango.min} ${etiquetaUnidad(rango.unidad as any)}`
    : `${rango.min}–${rango.max} ${etiquetaUnidad(rango.unidad as any)}`
  : null;
---

<article
  class="tarjeta group flex flex-col bg-white rounded-xl overflow-hidden shadow-sm border border-navy/10 hover:shadow-md transition-shadow"
  data-card
  data-nombre={proyecto.nombre.toLowerCase()}
  data-tipo={proyecto.tipo}
  data-departamento={proyecto.departamento.toLowerCase()}
  data-municipio={proyecto.municipio.toLowerCase()}
  data-estado={proyecto.estado}
  data-precio={proyecto.precioDesde ?? ""}
  data-area={rango ? rango.min : ""}
  data-disp={disponibles}
>
  <div class="relative h-44 overflow-hidden">
    <a href={`/proyectos/${proyecto.slug}`} class="block h-full">
      <img
        src={proyecto.galeria[0]}
        alt={`${proyecto.nombre}, ${proyecto.municipio}, ${proyecto.departamento}`}
        class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
        width="400"
        height="267"
      />
    </a>
    <div class="absolute top-2 left-2 flex flex-col items-start gap-1">
      <span class="text-xs font-semibold uppercase tracking-wide text-navy bg-sand px-2 py-1 rounded">
        Venta
      </span>
      <span class="text-xs font-semibold uppercase tracking-wide text-sand bg-navy/90 px-2 py-1 rounded">
        {labelEstado[proyecto.estado]}
      </span>
    </div>
    <button
      type="button"
      class="fav-btn absolute top-2 right-2 grid h-9 w-9 place-items-center rounded-full bg-white/90 shadow-sm hover:bg-white transition-colors"
      data-fav
      data-fav-slug={proyecto.slug}
      aria-label={`Guardar ${proyecto.nombre} en favoritos`}
      aria-pressed="false"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="fav-icon h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
      </svg>
    </button>
  </div>

  <div class="flex flex-1 flex-col p-4">
    <a href={`/proyectos/${proyecto.slug}`} class="block">
      <h3 class="font-display text-lg leading-tight">{proyecto.nombre}</h3>
      <p class="text-sm text-navy/60 mt-0.5">{proyecto.municipio}, {proyecto.departamento}</p>
    </a>

    <p class="text-sand font-semibold mt-2">{proyecto.etiquetaPrecio}</p>

    <!-- Fila de íconos: área, tipo, servicios clave -->
    <ul class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-navy/70 border-t border-navy/10 pt-3">
      {areaTexto && (
        <li class="flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-sand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4h4M16 4h4v4M20 16v4h-4M8 20H4v-4" />
          </svg>
          {areaTexto}
        </li>
      )}
      <li class="flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-sand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v10h14V10" />
        </svg>
        {labelTipo[proyecto.tipo]}
      </li>
      {proyecto.servicios.length > 0 && (
        <li class="flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-sand" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          {proyecto.servicios.length} servicios
        </li>
      )}
    </ul>
  </div>
</article>
