// Esquema de datos del Agente de Redes Sociales de Destinopropiedades.com
// Motor: SQLite (cero configuración en local). Migrable a Postgres en producción.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Postgres para despliegue (Vercel/Neon). Para desarrollo local también se
  // usa Postgres (p.ej. una rama gratuita de Neon) vía DATABASE_URL.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Usuario del área privada. Roles:
///   admin  → Director1: único con acceso al panel ARS.
///   sales  → ventas1..ventas5: se dirigen al CRM (no a ARS).
/// La contraseña se guarda hasheada (scrypt). Todos parten de "password" y la
/// pueden cambiar desde su panel.
model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String   @default("sales") // admin | sales
  displayName  String   @default("") // nombre visible del vendedor
  phone        String   @default("") // WhatsApp del usuario (para reportes)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  leads      Lead[]     @relation("AssignedLeads")
  activities Activity[]
}

/// Imagen generada (embellecida) almacenada directamente en la base de datos.
/// Evita depender de un almacenamiento externo (Vercel Blob). Se sirve pública
/// vía /api/img/<id>. Volumen pequeño (unas decenas de imágenes).
model StoredImage {
  id        String   @id @default(cuid())
  mimeType  String   @default("image/jpeg")
  bytes     Bytes
  createdAt DateTime @default(now())
}

/// Programación de reportes automáticos (director). Dos tipos:
///  - director_summary: resumen enviado al móvil del director.
///  - seller_portfolio: reporte diario a CADA vendedor con su cartera.
model ReportSchedule {
  id          String    @id @default(cuid())
  kind        String    @default("director_summary") // director_summary | seller_portfolio
  period      String    @default("daily") // daily | weekly | monthly
  hour        Int       @default(7) // hora de envío (0-23), hora de El Salvador
  channel     String    @default("whatsapp")
  destination String    @default("") // teléfono destino (para director_summary)
  enabled     Boolean   @default(true)
  lastRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ======================= CRM =======================
// CRM de ventas inmobiliarias. Diseñado "enlatado" (white-label): cada registro
// pertenece a una Organización (hoy Grupo Chacón; mañana otros grupos). El
// input llega de 3 fuentes: WhatsApp (principal), retroalimentación del vendedor
// y seguimiento del director.

/// Organización/cliente del CRM (multi-tenant para el modelo "enlatado").
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  leads Lead[]
}

/// Un prospecto/oportunidad de venta. Es el corazón del CRM.
model Lead {
  id             String    @id @default(cuid())
  orgId          String
  // Contacto
  name           String
  phone          String    @default("") // número de WhatsApp
  email          String    @default("")
  // Origen del lead
  source         String    @default("whatsapp") // whatsapp | referido | portal | facebook | instagram | tiktok | walk_in | otro
  // Interés
  projectSlug    String    @default("") // proyecto del portal que le interesa
  projectName    String    @default("")
  budget         String    @default("") // presupuesto declarado
  value          Float     @default(0) // valor estimado de la oportunidad (USD)
  // Estado en el embudo
  stage          String    @default("nuevo") // nuevo|contactado|calificado|visita|propuesta|negociacion|ganado|perdido
  temperature    String    @default("tibio") // frio | tibio | caliente
  lostReason     String    @default("") // motivo si se pierde
  // Asignación y seguimiento
  assignedToId   String?
  nextActionAt   DateTime? // próxima acción / follow-up (clave para reportes)
  nextActionNote String    @default("")
  lastContactAt  DateTime?
  notes          String    @default("") // ficha libre
  // --- Integración WhatsApp (bot movido por Claude, se conecta luego) ---
  /// Identificador del hilo/conversación de WhatsApp (lo provee el bot externo)
  /// para poder mapear mensajes entrantes al mismo lead. Sirve de clave estable.
  waThreadId     String    @default("")
  /// Momento en que el bot entregó la conversación a un asesor humano (handoff).
  handoffAt      DateTime?
  /// Quién maneja ahora la conversación: "bot" o "seller".
  handledBy      String    @default("bot") // bot | seller
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignedTo   User?         @relation("AssignedLeads", fields: [assignedToId], references: [id], onDelete: SetNull)
  activities   Activity[]
  appointments Appointment[]
}

/// Cita/visita agendada. La puede crear el bot de WhatsApp (sin intervención
/// humana), el vendedor o el director. Aparece en la agenda del CRM del vendedor
/// y en el log del cliente.
model Appointment {
  id          String   @id @default(cuid())
  leadId      String
  sellerId    String?  // User (vendedor) responsable
  scheduledAt DateTime
  location    String   @default("")
  notes       String   @default("")
  status      String   @default("scheduled") // scheduled | done | canceled | no_show
  createdBy   String   @default("bot") // bot | seller | director
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

/// Interacción en la línea de tiempo del lead. Captura las 3 fuentes de input:
/// WhatsApp, retroalimentación del vendedor y seguimiento del director.
model Activity {
  id        String    @id @default(cuid())
  leadId    String
  userId    String?
  // whatsapp | nota | llamada | visita | email | tarea | etapa | director
  type      String    @default("nota")
  body      String    @default("")
  // Para tareas / follow-ups:
  dueAt     DateTime?
  done      Boolean   @default(false)
  // Para cambios de etapa: de/hacia
  fromStage String    @default("")
  toStage   String    @default("")
  createdAt DateTime  @default(now())

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

/// Estrategia general de marca del portal (singleton, id = "default").
/// Es la "instrucción estratégica" de alto nivel que alimenta a toda la generación.
model BrandStrategy {
  id                  String   @id @default("default")
  brandName           String   @default("Destino Propiedades")
  portalUrl           String   @default("https://destinopropiedades.com")
  mission             String   @default("")
  toneOfVoice         String   @default("Cercano, aspiracional, profesional y confiable")
  targetAudience      String   @default("")
  generalInstructions String   @default("")
  defaultHashtags     String   @default("[]") // JSON array de strings
  language            String   @default("es")
  /// Instrucción Madre: prompt raíz de marca (subible o editable desde el dashboard).
  masterInstruction   String   @default("")
  /// Aprendizajes acumulados por el sistema de autoevaluación: ajustes de
  /// estrategia basados en el rendimiento real (métricas por red/proyecto).
  /// Se inyectan en la generación para mejorar continuamente.
  learnings           String   @default("")
  updatedAt           DateTime @updatedAt
}

/// Un proyecto inmobiliario del portafolio del portal.
model Project {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  location     String   @default("")
  propertyType String   @default("") // ej. Apartamento, Casa, Lote, Comercial
  status       String   @default("active") // active | paused | sold_out | archived
  /// Autopiloto: ¿ARS genera posts diarios de este proyecto automáticamente?
  autoPost     Boolean  @default(true)
  /// Redes en las que rota la calendarización diaria (JSON). Vacío = todas.
  postNetworks String   @default("[]")
  priceFrom    String   @default("")
  currency     String   @default("USD")
  description  String   @default("")
  amenities    String   @default("[]") // JSON array
  highlights   String   @default("[]") // JSON array (puntos de venta)
  hashtags     String   @default("[]") // JSON array (hashtags propios del proyecto)
  websiteUrl   String   @default("")
  contactInfo  String   @default("")
  /// Novedad puntual traída del feed del portal (/proyectos.json): algo
  /// concreto a comunicar en redes (rebaja, amenidad nueva, evento…). La
  /// escribe el dueño en el portal; el ARS la prioriza al generar posts.
  novedad      String   @default("")
  /// Ficha/instrucción específica del proyecto (subible o editable): target,
  /// persona, narrativa, número de WhatsApp. Tiene prioridad sobre los defaults.
  instructionDoc String @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  campaigns Campaign[]
  assets    Asset[]
  posts     Post[]
}

/// Una campaña de mercadeo: puede ser global (projectId null) o por proyecto.
model Campaign {
  id           String    @id @default(cuid())
  projectId    String?
  name         String
  objective    String    @default("awareness") // awareness | leads | sales | launch | event
  instructions String    @default("") // instrucción específica de la campaña
  networks     String    @default("[]") // JSON array: ["facebook","instagram","x","tiktok"]
  startDate    DateTime?
  endDate      DateTime?
  status       String    @default("active") // active | paused | finished
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  posts   Post[]
}

/// Imagen del "stock" reutilizable. Puede ser global (projectId null) o de un proyecto.
model Asset {
  id           String   @id @default(cuid())
  projectId    String?
  filename     String // nombre en disco/almacenamiento
  originalName String   @default("")
  url          String // ruta pública servida por /api/uploads/<filename>
  mimeType     String   @default("image/jpeg")
  sizeBytes    Int      @default(0)
  width        Int      @default(0)
  height       Int      @default(0)
  tags         String   @default("[]") // JSON array
  /// Si es una imagen embellecida, el id del Asset original del que salió.
  /// Sirve para no duplicar embellecidas del mismo origen (una por estilo).
  sourceAssetId String  @default("")
  createdAt    DateTime @default(now())

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
}

/// Análisis de una campaña hecho por Claude: validación, comparación contra
/// campañas previas, tendencias y métricas, con recomendaciones concretas que
/// el director puede autorizar en combo. Es también el "log" de la campaña.
model CampaignAnalysis {
  id              String   @id @default(cuid())
  campaignId      String
  summary         String   @default("") // diagnóstico general
  comparison      String   @default("") // vs campañas anteriores / tendencias
  /// Recomendaciones puntuales (JSON): [{field,label,current,suggested,reason}]
  recommendations String   @default("[]")
  appliedFields   String   @default("[]") // campos aplicados por el director (JSON)
  createdAt       DateTime @default(now())
}

/// Un post generado por el bot, listo para revisión/aprobación y publicación.
model Post {
  id          String    @id @default(cuid())
  projectId   String?
  campaignId  String?
  network     String // facebook | instagram | x | tiktok
  status      String    @default("draft") // draft | approved | scheduled | publishing | published | rejected | failed
  caption     String    @default("")
  hashtags    String    @default("[]") // JSON array
  assetIds    String    @default("[]") // JSON array de Asset.id
  callToAction String   @default("")
  scheduledAt DateTime?
  publishedAt DateTime?
  externalId  String?
  externalUrl String?
  error       String?
  model       String?   @default("") // modelo de IA usado
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project  Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  metric   PostMetric?
}

/// Métricas de impacto de un post publicado (al estilo Meta Business).
/// Snapshot más reciente conocido. Origen: entrada manual hoy; en Fase 2 se
/// llena automáticamente desde las APIs de cada red (Meta/X/TikTok).
model PostMetric {
  id          String   @id @default(cuid())
  postId      String   @unique
  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0) // compartidos / reposts / retweets
  impressions Int      @default(0) // veces que se mostró
  reach       Int      @default(0) // cuentas únicas alcanzadas
  clicks      Int      @default(0) // clics al enlace / WhatsApp
  saves       Int      @default(0) // guardados
  source      String   @default("manual") // manual | meta | x | tiktok
  capturedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

/// Autoevaluación periódica de la estrategia: análisis del rendimiento real
/// (métricas por red/proyecto) con recomendaciones concretas de ajuste.
model StrategyReview {
  id              String   @id @default(cuid())
  periodStart     DateTime
  periodEnd       DateTime
  scope           String   @default("global") // global | <projectId>
  summary         String   @default("") // qué funcionó y qué no
  recommendations String   @default("") // ajustes concretos propuestos
  metricsSnapshot String   @default("{}") // JSON con los agregados usados
  applied         Boolean  @default(false) // si se incorporó a la estrategia
  createdAt       DateTime @default(now())
}

/// Configuración de automatización de ARS (singleton, id = "default").
/// Controla los loops autónomos: generación diaria, investigación quincenal de
/// tendencias, autoactualización de la instrucción y chequeo mensual de ventas.
model Automation {
  id                    String    @id @default("default")
  /// Autopiloto general: genera borradores diarios por proyecto/red.
  autopilot             Boolean   @default(false)
  /// Redes por defecto para la generación diaria (JSON array).
  dailyNetworks         String    @default("[\"facebook\",\"instagram\",\"x\",\"tiktok\"]")
  /// Borradores por proyecto por día.
  postsPerDay           Int       @default(1)
  /// Loop quincenal de investigación de tendencias mundiales.
  trendsLoop            Boolean   @default(true)
  /// Autoactualización quincenal de la instrucción con base en tendencias+métricas.
  autoUpdateInstruction Boolean   @default(true)
  /// Día del mes para pedir el reporte de ventas (1–28).
  salesCheckinDay       Int       @default(1)
  /// Proveedor de generación de video (ej. "runway", "replicate"). Vacío = off.
  videoProvider         String    @default("")
  lastDailyRun          DateTime?
  lastTrendsRun         DateTime?
  lastSalesCheckin      DateTime?
  updatedAt             DateTime  @updatedAt
}

/// Chequeo mensual de ventas: ARS pregunta cómo van las ventas para
/// retroalimentar la instrucción con efectividad real.
model SalesCheckin {
  id        String   @id @default(cuid())
  period    String   @unique // "YYYY-MM"
  answered  Boolean  @default(false)
  salesNote String   @default("") // respuesta del operador
  askedAt   DateTime @default(now())
  answeredAt DateTime?
}

/// Conexión a una cuenta de red social y su modo de publicación.
model SocialAccount {
  id          String   @id @default(cuid())
  network     String   @unique // facebook | instagram | x | tiktok
  displayName String   @default("")
  enabled     Boolean  @default(false)
  autoPublish Boolean  @default(false) // Fase 2: publicar sin aprobación humana
  config      String   @default("{}") // JSON con credenciales/ids específicos
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
