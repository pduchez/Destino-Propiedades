# ============================================================
#  Destino Social Agent — variables de entorno
#  Copia este archivo a .env y completa los valores.
# ============================================================

# --- Base de datos (PostgreSQL) ---
# Local y producción usan Postgres. Para local puedes crear una base gratuita en
# https://neon.tech (o https://supabase.com) y pegar aquí la cadena de conexión.
# Vercel inyecta esta variable automáticamente si añades Vercel Postgres / Neon.
DATABASE_URL="postgresql://usuario:password@host/db?sslmode=require"

# --- Motor de IA (Anthropic / Claude) ---
# Crea una API key en https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."
# Modelo a usar para generar los copys. Por defecto el más capaz.
# Alternativas más económicas para alto volumen: claude-sonnet-4-6
AI_MODEL="claude-opus-4-8"

# --- Seguridad del dashboard ---
# Token simple para proteger el dashboard y las APIs (cabecera o cookie).
# Genera uno largo y aleatorio. Si se deja vacío, el dashboard queda abierto (solo dev).
DASHBOARD_PASSWORD=""

# --- Almacenamiento de imágenes ---
# "local" guarda en ./uploads (desarrollo). "blob" sube a Vercel Blob (producción).
STORAGE_DRIVER="local"
# Token de Vercel Blob (solo si STORAGE_DRIVER="blob"). Vercel lo inyecta
# automáticamente al crear un Blob Store en el proyecto.
BLOB_READ_WRITE_TOKEN=""

# ============================================================
#  Credenciales de redes sociales (Fase 2 — publicación)
#  En Fase 1 (aprobación humana) NO son obligatorias: el bot
#  genera borradores y se publica manualmente. Complétalas
#  cuando quieras publicar directamente desde el dashboard.
# ============================================================

# --- Meta (Facebook + Instagram) — Graph API ---
# https://developers.facebook.com  (App + Página + cuenta IG Business vinculada)
META_PAGE_ID=""
META_PAGE_ACCESS_TOKEN=""
META_IG_USER_ID=""
META_GRAPH_VERSION="v21.0"

# --- X (Twitter) — API v2 (OAuth 1.0a user context para publicar) ---
X_API_KEY=""
X_API_SECRET=""
X_ACCESS_TOKEN=""
X_ACCESS_SECRET=""

# --- TikTok — Content Posting API ---
# https://developers.tiktok.com
TIKTOK_ACCESS_TOKEN=""

# ============================================================
#  Video (JSON2Video) — reels 9:16 con fotos reales + texto + música
# ============================================================
# API key de https://json2video.com (Settings → API Keys).
JSON2VIDEO_API_KEY=""
# (Opcional) URL pública de una pista de música LIBRE de derechos para el fondo.
# Si se deja vacío, el reel se genera sin música.
JSON2VIDEO_MUSIC_URL=""
# (Opcional) Logo de la marca (PNG/SVG, versión clara) para el intro del reel.
# Si se deja vacío, el reel omite el logo y usa solo el nombre.
VIDEO_LOGO_URL=""
# (Opcional) Color de acento de marca para los reels (dorado por defecto).
VIDEO_ACCENT_COLOR="#C9A463"
# (Opcional) Secreto para proteger los crons y el webhook de render.
CRON_SECRET=""

# URL pública base (para construir URLs absolutas de las imágenes al publicar).
# En local: http://localhost:3000  — en prod: https://tu-dominio
PUBLIC_BASE_URL="http://localhost:3000"
